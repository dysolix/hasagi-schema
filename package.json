{
  "name": "@hasagi/schema",
  "version": "0.7.1",
  "private": true,
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:package": "npm run build && publint ./dist && attw --pack ./dist --ignore-rules cjs-resolves-to-esm",
    "test": "npm run test:typecheck && vitest run",
    "test:typecheck": "tsc -p tsconfig.test.json",
    "release": "npm run check:package && cd ./dist && npm publish --access public",
    "changelog": "node scripts/changelog-stub.mjs",
    "postversion": "npm run changelog",
    "version:patch": "npm version patch --ignore-scripts=false",
    "version:minor": "npm version minor --ignore-scripts=false",
    "version:major": "npm version major --ignore-scripts=false"
  },
  "keywords": [
    "hasagi"
  ],
  "author": "dysolix",
  "license": "MIT",
  "dependencies": {
    "@hasagi/core": "0.7.0",
    "axios": "^1.17.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^20.19.42",
    "prettier": "^3.5.3",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "exports": {
    ".": "./index.js"
  },
  "types": "./index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dysolix/hasagi-schema.git"
  }
}
