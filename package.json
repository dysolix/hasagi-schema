{
  "name": "@hasagi/schema",
  "version": "0.7.0",
  "private": true,
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:package": "npm run build && publint ./dist && attw --pack ./dist --ignore-rules cjs-resolves-to-esm",
    "release": "npm run check:package && cd ./dist && npm publish --access public"
  },
  "keywords": [
    "hasagi"
  ],
  "author": "dysolix",
  "license": "MIT",
  "dependencies": {
    "@hasagi/core": "^0.7.0",
    "axios": "^1.17.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@types/node": "^20.19.42",
    "prettier": "^3.5.3",
    "publint": "^0.3.21",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": "./index.js"
  },
  "types": "./index.d.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dysolix/hasagi-schema.git"
  }
}
