{
    "compilerOptions": {
        "target": "ES2022",
        "module": "node16",
        "moduleResolution": "node16",

        "types": ["node"],

        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true,

        "strict": true,

        "declaration": true,
        "allowJs": true,

        "outDir": "dist",
        "rootDir": "src",

        "forceConsistentCasingInFileNames": true,

        "allowSyntheticDefaultImports": true,
    },
    "include": [ "./src" ]
}